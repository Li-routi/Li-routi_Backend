# 서버 /opt/app/.env 로 복사한 뒤 실제 값을 채운다.
# 이 example만 레포에 커밋하고, 실제 .env 는 절대 커밋하지 않는다(서버 전용).
# docker-compose.prod.yml 이 여기 값을 ${...} 로 주입한다.

# --- DB (compose의 mysql 컨테이너가 이 값으로 초기화됨) ---
DB_ROOT_PASSWORD=change-me-root
DB_PASSWORD=change-me-app

# --- 애플리케이션 필수 비밀값 (없으면 부팅 실패: fail-fast) ---
JWT_SECRET=change-me-32bytes-이상-랜덤-문자열
KAKAO_APP_ID=1234567890
GOOGLE_WEB_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_ALLOWED_ISSUERS=https://accounts.google.com

# --- AWS S3 (미디어 업로드 presigned URL) ---
# 자격증명은 여기 두지 않는다 — EC2 instance profile(IAM Role)로 SDK가 자동 획득.
AWS_S3_BUCKET=lirouti-prod-bucket
AWS_REGION=ap-northeast-2
# (선택) 저장된 미디어를 읽을 공개 주소. 미설정이면 compose가 위 버킷·리전으로
# https://s3.<리전>.amazonaws.com/<버킷> (path-style)을 계산해 쓴다(버킷이 공개면 그대로 동작).
# CloudFront 등을 붙이면 그 도메인으로 이 값을 채워 오리진을 덮어쓴다.
# AWS_S3_PUBLIC_BASE_URL=https://xxxxxxxx.cloudfront.net

# --- 배포 이미지 태그 ---
# 평소엔 latest(자동 배포는 항상 최신). 롤백할 때만 이전 버전 태그로 바꾼다(예: v0.9.0).
APP_IMAGE_TAG=latest
